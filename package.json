{
  "name": "familias-colaboradoras-frontend",
  "version": "1.0.0",
  "description": "Frontend for Familias Colaboradoras - School Activity Management",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:combined": "node server.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "cf:upload": "npm run build && npx wrangler versions upload --assets=./dist --name familias-colaboradoras-frontend --compatibility-date 2026-03-03 --config ./wrangler.jsonc",
    "cf:deploy": "npm run build && npx wrangler deploy --config ./wrangler.jsonc"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.19",
    "@mui/material": "^5.14.20",
    "@mui/x-date-pickers": "^6.18.3",
    "@sentry/react": "^10.38.0",
    "@tanstack/react-query": "^5.8.4",
    "axios": "^1.6.2",
    "dayjs": "^1.11.10",
    "framer-motion": "^12.34.0",
    "notistack": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.48.2",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.8.0",
    "workbox-window": "^7.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "express": "^4.18.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jsdom": "^22.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "http-proxy-middleware": "^2.0.6",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^0.34.6",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "keywords": [
    "react",
    "typescript",
    "pwa",
    "school",
    "agenda",
    "cartama"
  ],
  "author": "Familias Colaboradoras Team",
  "license": "MIT"
}
